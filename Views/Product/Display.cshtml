@model WebLinkKienOTO.Models.Product
@{
    ViewData["Title"] = "Product Details";
}

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-12">
                <div class="custom-text-block shadow-lg rounded-4 overflow-hidden bg-white">

                    <div class="product-image-container">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="img-fluid w-100" alt="@Model.Name" style="max-height: 500px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light d-flex justify-content-center align-items-center" style="height: 400px;">
                                <i class="bi-image text-muted" style="font-size: 5rem; opacity: 0.3;"></i>
                            </div>
                        }
                    </div>

                    <div class="p-5">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h2 class="text-primary fw-bold mb-0">@Model.Name</h2>

                   
                            <span class="badge bg-light text-dark border rounded-pill px-3">
                                <i class="bi-qr-code-scan me-1"></i> Mã SP: @Model.Id.ToString("D4")
                               
                            </span>
                        </div>

                        <h3 class="text-success fw-bold mb-4">$@Model.Price</h3>

                        <div class="mb-4">
                            <h5 class="fw-bold border-bottom pb-2">Description</h5>
                            <p class="text-muted leading-relaxed">
                                @(string.IsNullOrEmpty(Model.Description) ? "No description available for this product." : Model.Description)
                            </p>
                        </div>

                        <div class="d-flex gap-3 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi-arrow-left me-1"></i> Back to List
                            </a>
                            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill px-4 ms-auto">
                                <i class="bi-pencil-square me-1"></i> Edit Product
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
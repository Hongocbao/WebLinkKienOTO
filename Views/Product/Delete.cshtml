@model WebLinkKienOTO.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-12">
                <div class="custom-text-block shadow-lg rounded-4 p-5 bg-white border-top border-5 border-danger text-center">

                    <div class="mb-4">
                        <i class="bi-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
                    </div>

                    <h2 class="mb-3 text-danger">Confirm Deletion</h2>
                    <p class="text-muted mb-4">Are you absolutely sure you want to delete this product? This action cannot be undone.</p>

                    <div class="card border-0 bg-light rounded-4 p-4 text-start mb-5 shadow-sm">
                        <h4 class="fw-bold mb-2">@Model.Name</h4>
                        <h5 class="text-success mb-3">$@Model.Price</h5>
                        <p class="text-muted mb-0 small">@Model.Description</p>
                    </div>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-secondary rounded-pill px-5 fw-bold">Cancel</a>
                            <button type="submit" class="btn btn-danger rounded-pill px-5 fw-bold shadow-sm">
                                <i class="bi-trash me-1"></i> Yes, Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>